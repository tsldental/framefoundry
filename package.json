{
  "name": "davm",
  "version": "0.1.0",
  "description": "Deterministic Agent Virtual Machine for recording and replaying agent sessions.",
  "bin": {
    "davm": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm --prefix visualizer run build",
    "build:server": "tsc -p tsconfig.json",
    "build:visualizer": "npm --prefix visualizer run build",
    "demo": "node dist/index.js",
    "serve": "node dist/server.js",
    "visualizer:dev": "npm --prefix visualizer run dev"
  },
  "keywords": [
    "agent",
    "deterministic",
    "replay",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^1.0.0-beta.4",
    "better-sqlite3": "^12.10.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
